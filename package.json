{
  "name": "@ubercode/pino-cloudwatch",
  "version": "1.0.1",
  "description": "A TypeScript pino v7+ transport for Amazon CloudWatch Logs.",
  "keywords": [
    "amazon",
    "aws",
    "cloudwatch",
    "pino",
    "pino-transport",
    "log",
    "logs",
    "logging",
    "cloud",
    "typescript"
  ],
  "author": "Michael Lee Hobbs <michael.lee.hobbs@gmail.com> (https://github.com/MichaelLeeHobbs)",
  "contributors": [
    "David Howell <david@dynamicmethods.com.au>"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.33.4",
  "peerDependencies": {
    "pino": "^8.0.0 || ^9.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1050.0",
    "bottleneck": "^2.19.5",
    "debug": "^4.4.3",
    "pino-abstract-transport": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@types/debug": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jiti": "^2.5.1",
    "lint-staged": "^17.0.5",
    "pino": "^9.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "prepublishOnly": "pnpm run test && pnpm run build",
    "preversion": "pnpm run test && pnpm run build",
    "postversion": "git push && git push --tags",
    "version:major": "npm version major",
    "version:minor": "npm version minor",
    "version:patch": "npm version patch",
    "dry-run": "npm pack --dry-run",
    "example": "ts-node examples/basic-usage.ts",
    "test": "pnpm run test:format && pnpm run test:lint && pnpm run test:unit",
    "test:format": "prettier --check \"{src,tests}/**/*.{ts,js,json,md}\" \"*.{mts,ts,json}\" \".github/**/*.yml\"",
    "test:lint": "eslint",
    "test:unit": "node --max-old-space-size=6144 node_modules/jest/bin/jest.js",
    "test:cover": "node --max-old-space-size=6144 node_modules/jest/bin/jest.js --coverage",
    "test:watch": "node --max-old-space-size=6144 node_modules/jest/bin/jest.js --watch",
    "test:stress": "node --expose-gc --max-old-space-size=6144 node_modules/jest/bin/jest.js --config jest.stress.config.ts --runInBand",
    "test:ci": "pnpm run test:format && pnpm run test:lint && pnpm run test:cover",
    "format": "prettier --write \"{src,tests}/**/*.{ts,js,json,md}\" \"*.{mts,ts,json}\" \".github/**/*.yml\"",
    "lint": "eslint --fix",
    "precommit": "lint-staged"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MichaelLeeHobbs/pino-cloudwatch-ts.git"
  },
  "homepage": "https://github.com/MichaelLeeHobbs/pino-cloudwatch-ts#readme",
  "bugs": {
    "url": "https://github.com/MichaelLeeHobbs/pino-cloudwatch-ts/issues"
  },
  "license": "MIT",
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write",
    "*.{ts,js}": "eslint --fix"
  }
}
